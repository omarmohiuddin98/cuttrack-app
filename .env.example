# Copy this file to .env.local for local development,
# and add the same two values in Vercel → Project → Settings → Environment Variables.

# Supabase → Project Settings → API → Project URL
SUPABASE_URL=

# Supabase → Project Settings → API → service_role secret key
# (NOT the anon/public key — this one has full access, keep it server-side only,
# which is exactly how this app uses it: only inside app/api/* route files.)
SUPABASE_SERVICE_ROLE_KEY=

# Password required to view/use the Inventory tab (pick any value).
INVENTORY_PASSWORD=
